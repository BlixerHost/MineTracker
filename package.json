{
  "name": "minetracker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @minetracker/api prisma generate",
    "db:migrate": "pnpm --filter @minetracker/api prisma migrate dev",
    "db:migrate:prod": "pnpm --filter @minetracker/api prisma migrate deploy",
    "db:studio": "pnpm --filter @minetracker/api prisma studio",
    "db:seed": "pnpm --filter @minetracker/api prisma db seed"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@11.5.2"
}
